import { useState, useEffect, ChangeEvent } from 'react';
import api from '../../lib/api';
import { useRouter } from 'next/router';
import useRequireAuth from '../../hooks/useRequireAuth';
import ProtectedRoute from '../../components/ProtectedRoute';
import { useStores, useCategories } from '../../hooks/useSync';
import { useAuth } from '../../contexts/AuthContext';

export default function CreateProduct() {
  useRequireAuth(['lojista']);
  const { user } = useAuth();
  const { stores } = useStores();
  const { categories, setCategories } = useCategories(
    stores?.find((s: any) => s.ownerId === user?.id || s.ownerId === user?._id)?._id
  );
  
  const storeId = stores?.find((s: any) => s.ownerId === user?.id || s.ownerId === user?._id)?._id || '';
  const [loading, setLoading] = useState(false);
  const [name, setName] = useState('');
  const [description, setDescription] = useState('');
  const [price, setPrice] = useState(0);
  const [quantity, setQuantity] = useState(0);
  const [category, setCategory] = useState('');
  const [newCategory, setNewCategory] = useState('');
  const [image, setImage] = useState<File | null>(null);
  const [imagePreview, setImagePreview] = useState<string | null>(null);
  const [drafts, setDrafts] = useState<any[]>([]);
  const [showNewCategoryForm, setShowNewCategoryForm] = useState(false);
  const router = useRouter();

  // Handle image selection with preview
  const handleImageSelect = (e: ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      setImage(file);
      const reader = new FileReader();
      reader.onload = (ev) => {
        setImagePreview(ev.target?.result as string);
      };
      reader.readAsDataURL(file);
    }
  };


  // Adiciona produto à lista de rascunhos
  const addDraft = (e: any) => {
    e.preventDefault();
    if (!name.trim() || !storeId) return alert('Preencha o nome do produto');
    if (!price || price < 0) return alert('Insira um preço válido');
    if (!quantity || quantity < 0) return alert('Insira uma quantidade válida');
    
    const reader = imagePreview ? null : null;
    setDrafts((prev) => [...prev, {
      storeId, 
      name, 
      description,
      price, 
      quantity, 
      category, 
      image: imagePreview, 
      imageName: image?.name
    }]);
    resetForm();
  };

  const resetForm = () => {
    setName('');
    setDescription('');
    setPrice(0);
    setQuantity(0);
    setCategory('');
    setImage(null);
    setImagePreview(null);
  };

  // Envia todos os rascunhos para o backend
  const launchAll = async () => {
    if (drafts.length === 0) return;
    try {
      let successCount = 0;
      for (const draft of drafts) {
        // Monta payload seguro
        const payload: any = {
          storeId: draft.storeId,
          name: draft.name,
          description: draft.description || '',
          price: Number(draft.price),
          quantity: draft.quantity !== undefined ? Number(draft.quantity) : 0
        };
        if (draft.category) payload.category = draft.category;
        if (draft.image) {
          const form = new FormData();
          Object.entries(payload).forEach(([k, v]) => form.append(k, String(v)));
          form.append('image', dataURLtoFile(draft.image, draft.imageName || 'imagem.jpg'));
          await api.post('/products', form, { headers: { 'Content-Type': 'multipart/form-data' } });
        } else {
          await api.post('/products', payload);
        }
        successCount++;
      }
      setDrafts([]);
      alert(`✅ ${successCount} produto(s) criado(s) com sucesso!`);
      router.push('/seller/products');
    } catch (err: any) {
      alert(err?.response?.data?.error || 'Falha ao lançar produtos');
    }
  };

  // Utilitário para converter dataURL em File
  function dataURLtoFile(dataurl: string, filename: string) {
    const arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1], bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);
    for (let i = 0; i < n; i++) u8arr[i] = bstr.charCodeAt(i);
    return new File([u8arr], filename, { type: mime });
  }

  // Criação rápida de categoria
  const handleAddCategory = async () => {
    if (!newCategory.trim() || !storeId) return;
    setLoading(true);
    try {
      await api.post('/categories', { storeId, name: newCategory });
      setNewCategory('');
      setShowNewCategoryForm(false);
    } catch (err: any) {
      alert(err?.response?.data?.error || 'Erro ao criar categoria');
    } finally {
      setLoading(false);
    }    }
  };

  return (
    <ProtectedRoute required_role="lojista">
      <div style={{ minHeight: '100vh', background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)', padding: '24px 16px', fontFamily: 'system-ui, -apple-system, sans-serif' }}>
        <div style={{ maxWidth: 1200, margin: '0 auto' }}>
          {/* Header */}
          <div style={{ marginBottom: 32, color: '#fff' }}>
            <h1 style={{ fontSize: 32, fontWeight: 700, margin: '0 0 8px 0' }}>📦 Criar Produto</h1>
          <p style={{ fontSize: 16, margin: 0, opacity: 0.9 }}>Adicione novos produtos à sua loja</p>
        </div>

        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(500px, 1fr))', gap: 24 }}>
          {/* Formulário */}
          <div style={{ background: '#fff', borderRadius: 16, padding: 24, boxShadow: '0 8px 32px rgba(0,0,0,0.1)' }}>
            <h2 style={{ fontSize: 20, fontWeight: 600, marginTop: 0, marginBottom: 20, color: '#333' }}>Informações do Produto</h2>
            
            <form onSubmit={addDraft} style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
              {/* Nome */}
              <div>
                <label style={{ display: 'block', fontSize: 12, fontWeight: 600, color: '#555', marginBottom: 6, textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  📝 Nome do Produto
                </label>
                <input
                  type="text"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  placeholder="ex: Smartphone Samsung A50"
                  required
                  style={{
                    width: '100%',
                    padding: '12px 14px',
                    fontSize: 14,
                    border: '2px solid #e0e0e0',
                    borderRadius: 8,
                      boxSizing: 'border-box',
                      transition: 'all 0.2s',
                      outline: 'none'
                    }}
                    onFocus={(e) => e.target.style.borderColor = '#667eea'}
                    onBlur={(e) => e.target.style.borderColor = '#e0e0e0'}
                  />
                </div>

                {/* Descrição */}
                <div>
                  <label style={{ display: 'block', fontSize: 12, fontWeight: 600, color: '#555', marginBottom: 6, textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                    📄 Descrição
                  </label>
                  <textarea
                    value={description}
                    onChange={(e) => setDescription(e.target.value)}
                    placeholder="Describe seu produto aqui..."
                    style={{
                      width: '100%',
                      padding: '12px 14px',
                      fontSize: 14,
                      border: '2px solid #e0e0e0',
                      borderRadius: 8,
                      boxSizing: 'border-box',
                      fontFamily: 'inherit',
                      minHeight: 100,
                      resize: 'vertical',
                      transition: 'all 0.2s',
                      outline: 'none'
                    }}
                    onFocus={(e) => e.currentTarget.style.borderColor = '#667eea'}
                    onBlur={(e) => e.currentTarget.style.borderColor = '#e0e0e0'}
                  />
                </div>

                {/* Preço e Quantidade */}
                <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
                  <div>
                    <label style={{ display: 'block', fontSize: 12, fontWeight: 600, color: '#555', marginBottom: 6, textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                      💰 Preço (R$)
                    </label>
                    <input
                      type="number"
                      min="0"
                      step="0.01"
                      value={price}
                      onChange={(e) => setPrice(Number(e.target.value))}
                      required
                      style={{
                        width: '100%',
                        padding: '12px 14px',
                        fontSize: 14,
                        border: '2px solid #e0e0e0',
                        borderRadius: 8,
                        boxSizing: 'border-box',
                        outline: 'none'
                      }}
                      onFocus={(e) => e.currentTarget.style.borderColor = '#667eea'}
                      onBlur={(e) => e.currentTarget.style.borderColor = '#e0e0e0'}
                    />
                  </div>
                  <div>
                    <label style={{ display: 'block', fontSize: 12, fontWeight: 600, color: '#555', marginBottom: 6, textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                      📦 Quantidade
                    </label>
                    <input
                      type="number"
                      min="0"
                      value={quantity}
                      onChange={(e) => setQuantity(Number(e.target.value))}
                      required
                      style={{
                        width: '100%',
                        padding: '12px 14px',
                        fontSize: 14,
                        border: '2px solid #e0e0e0',
                        borderRadius: 8,
                        boxSizing: 'border-box',
                        outline: 'none'
                      }}
                      onFocus={(e) => e.currentTarget.style.borderColor = '#667eea'}
                      onBlur={(e) => e.currentTarget.style.borderColor = '#e0e0e0'}
                    />
                  </div>
                </div>

                {/* Categoria */}
                <div>
                  <label style={{ display: 'block', fontSize: 12, fontWeight: 600, color: '#555', marginBottom: 6, textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                    🏷️ Categoria
                  </label>
                  {catLoading ? (
                    <p style={{ margin: 0, fontSize: 13, color: '#888' }}>⏳ Carregando categorias...</p>
                  ) : (
                    <div style={{ display: 'flex', gap: 8 }}>
                      <select
                        value={category}
                        onChange={(e) => setCategory(e.target.value)}
                        style={{
                          flex: 1,
                          padding: '12px 14px',
                          fontSize: 14,
                          border: '2px solid #e0e0e0',
                          borderRadius: 8,
                          outline: 'none',
                          cursor: 'pointer'
                        }}
                      >
                        <option value="">Selecione uma categoria</option>
                        {categories.map((cat: any) => (
                          <option key={cat._id} value={cat._id}>{cat.name}</option>
                        ))}
                      </select>
                      <button
                        type="button"
                        onClick={() => setShowNewCategoryForm(!showNewCategoryForm)}
                        style={{
                          padding: '12px 16px',
                          fontSize: 14,
                          fontWeight: 600,
                          background: '#f0f0f0',
                          border: 'none',
                          borderRadius: 8,
                          cursor: 'pointer',
                          color: '#667eea',
                          transition: 'all 0.2s'
                        }}
                        onMouseOver={(e) => e.currentTarget.style.background = '#e8e8e8'}
                        onMouseOut={(e) => e.currentTarget.style.background = '#f0f0f0'}
                      >
                        ➕ Nova
                      </button>
                    </div>
                  )}
                  
                  {showNewCategoryForm && (
                    <div style={{ marginTop: 12, display: 'flex', gap: 8 }}>
                      <input
                        type="text"
                        value={newCategory}
                        onChange={(e) => setNewCategory(e.target.value)}
                        placeholder="Nome da nova categoria"
                        style={{
                          flex: 1,
                          padding: '10px 12px',
                          fontSize: 13,
                          border: '2px solid #667eea',
                          borderRadius: 6,
                          outline: 'none'
                        }}
                      />
                      <button
                        type="button"
                        disabled={catLoading}
                        onClick={handleAddCategory}
                        style={{
                          padding: '10px 16px',
                          fontSize: 13,
                          fontWeight: 600,
                          background: '#667eea',
                          color: '#fff',
                          border: 'none',
                          borderRadius: 6,
                          cursor: catLoading ? 'not-allowed' : 'pointer',
                          opacity: catLoading ? 0.6 : 1
                        }}
                      >
                        {catLoading ? '⏳' : '✓'} Criar
                      </button>
                    </div>
                  )}
                </div>

                {/* Imagem */}
                <div>
                  <label style={{ display: 'block', fontSize: 12, fontWeight: 600, color: '#555', marginBottom: 6, textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                    🖼️ Imagem do Produto
                  </label>
                  <div style={{
                    border: '2px dashed #667eea',
                    borderRadius: 8,
                    padding: 16,
                    textAlign: 'center',
                    cursor: 'pointer',
                    position: 'relative',
                    transition: 'all 0.2s',
                    background: imagePreview ? 'transparent' : '#f8f9ff'
                  }}>
                    {imagePreview ? (
                      <div style={{ position: 'relative', display: 'inline-block' }}>
                        <img src={imagePreview} alt="Preview" style={{ maxWidth: '100%', maxHeight: 200, borderRadius: 8 }} />
                        <button
                          type="button"
                          onClick={() => { setImage(null); setImagePreview(null); }}
                          style={{
                            position: 'absolute',
                            top: 4,
                            right: 4,
                            background: 'rgba(0,0,0,0.6)',
                            color: '#fff',
                            border: 'none',
                            borderRadius: '50%',
                            width: 32,
                            height: 32,
                            fontSize: 18,
                            cursor: 'pointer'
                          }}
                        >
                          ✕
                        </button>
                      </div>
                    ) : (
                      <div>
                        <p style={{ margin: 0, fontSize: 12, color: '#667eea', fontWeight: 600 }}>📤 Clique para selecionar uma imagem</p>
                        <p style={{ margin: '4px 0 0 0', fontSize: 11, color: '#999' }}>ou arraste aqui</p>
                      </div>
                    )}
                    <input
                      type="file"
                      accept="image/*"
                      onChange={handleImageSelect}
                      style={{
                        position: 'absolute',
                        top: 0,
                        left: 0,
                        width: '100%',
                        height: '100%',
                        opacity: 0,
                        cursor: 'pointer'
                      }}
                    />
                  </div>
                </div>

                {/* Botão Adicionar */}
                <button
                  type="submit"
                  style={{
                    marginTop: 8,
                    padding: '14px 20px',
                    fontSize: 15,
                    fontWeight: 700,
                    background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                    color: '#fff',
                    border: 'none',
                    borderRadius: 8,
                    cursor: 'pointer',
                    transition: 'all 0.2s',
                    boxShadow: '0 4px 12px rgba(102, 126, 234, 0.4)'
                  }}
                  onMouseOver={(e) => e.currentTarget.style.boxShadow = '0 6px 20px rgba(102, 126, 234, 0.6)'}
                  onMouseOut={(e) => e.currentTarget.style.boxShadow = '0 4px 12px rgba(102, 126, 234, 0.4)'}
                >
                  ➕ Adicionar à Rascunho
                </button>
              </form>

          <div>
            <div style={{ background: '#fff', borderRadius: 16, padding: 24, boxShadow: '0 8px 32px rgba(0,0,0,0.1)', marginBottom: 16 }}>
              <h2 style={{ fontSize: 20, fontWeight: 600, marginTop: 0, marginBottom: 20, color: '#333' }}>
                📋 Rascunhos ({drafts.length})
              </h2>
              
              {drafts.length === 0 ? (
                <div style={{ textAlign: 'center', padding: '40px 20px', color: '#999' }}>
                  <p style={{ fontSize: 14, margin: 0 }}>Nenhum produto em rascunho ainda</p>
                </div>
              ) : (
                <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
                  {drafts.map((draft, idx) => (
                    <div
                      key={idx}
                      style={{
                        background: '#f8f9ff',
                        border: '1px solid #e0e0e0',
                        borderRadius: 12,
                        padding: 12,
                        display: 'flex',
                        gap: 12
                      }}
                    >
                      {draft.image && (
                        <img
                          src={draft.image}
                          alt="Preview"
                          style={{
                            width: 80,
                            height: 80,
                            borderRadius: 8,
                            objectFit: 'cover',
                            flexShrink: 0
                          }}
                        />
                      )}
                      <div style={{ flex: 1, minWidth: 0 }}>
                        <h3 style={{ margin: '0 0 6px 0', fontSize: 14, fontWeight: 600, color: '#333' }}>
                          {draft.name}
                        </h3>
                        {draft.description && (
                          <p style={{ margin: '0 0 6px 0', fontSize: 12, color: '#666', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                            {draft.description}
                          </p>
                        )}
                        <div style={{ display: 'flex', gap: 12, fontSize: 12, color: '#777', flexWrap: 'wrap' }}>
                          <span>💰 R$ {draft.price.toFixed(2)}</span>
                          <span>📦 {draft.quantity} un</span>
                          {draft.category && categories.find(c => c._id === draft.category) && (
                            <span>🏷️ {categories.find(c => c._id === draft.category)?.name}</span>
                          )}
                        </div>
                      </div>
                      <button
                        type="button"
                        onClick={() => setDrafts(drafts.filter((_, i) => i !== idx))}
                        style={{
                          background: 'none',
                          border: 'none',
                          fontSize: 18,
                          cursor: 'pointer',
                          color: '#999',
                          padding: 0,
                          flexShrink: 0
                        }}
                      >
                        ✕
                      </button>
                    </div>
                  ))}
                </div>
              )}
            </div>

            {drafts.length > 0 && (
              <button
                onClick={launchAll}
                style={{
                  width: '100%',
                  padding: '16px 20px',
                  fontSize: 16,
                  fontWeight: 700,
                  background: 'linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%)',
                  color: '#fff',
                  border: 'none',
                  borderRadius: 12,
                  cursor: 'pointer',
                  transition: 'all 0.2s',
                  boxShadow: '0 4px 12px rgba(14, 165, 233, 0.4)'
                }}
                onMouseOver={(e) => e.currentTarget.style.boxShadow = '0 6px 20px rgba(14, 165, 233, 0.6)'}
                onMouseOut={(e) => e.currentTarget.style.boxShadow = '0 4px 12px rgba(14, 165, 233, 0.4)'}
              >
                🚀 Lançar Todos ({drafts.length})
              </button>
            )}

            {/* Links */}
            <div style={{ marginTop: 16, textAlign: 'center' }}>
              <a
                href="/seller/products"
                style={{
                  display: 'inline-block',
                  padding: '12px 20px',
                  fontSize: 14,
                  fontWeight: 600,
                  background: '#fff',
                  color: '#667eea',
                  border: '2px solid #667eea',
                  borderRadius: 8,
                  textDecoration: 'none',
                  cursor: 'pointer',
                  transition: 'all 0.2s'
                }}
                onMouseOver={(e) => { e.currentTarget.style.background = '#f0f0ff'; }}
                onMouseOut={(e) => { e.currentTarget.style.background = '#fff'; }}
              >
                📦 Meus Produtos
              </a>
            </div>
          </div>
        </div>
      </div>
    </ProtectedRoute>
  );
}
