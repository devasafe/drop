{
  "info": {
    "name": "Drop Marketplace - Basic",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Store (lojista)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{ \"name\": \"Minha Loja\", \"address\": \"Rua X\" }" },
        "url": { "raw": "http://localhost:4000/stores", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["stores"] }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{ \"name\": \"Test\", \"email\": \"test@example.com\", \"password\": \"pass\", \"role\": \"cliente\" }" },
        "url": { "raw": "http://localhost:4000/auth/register", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["auth","register"] }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{ \"email\": \"test@example.com\", \"password\": \"pass\" }" },
        "url": { "raw": "http://localhost:4000/auth/login", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["auth","login"] }
      }
    },
    {
      "name": "List products",
      "request": { "method": "GET", "url": { "raw": "http://localhost:4000/products", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["products"] } }
    }
    ,
    {
      "name": "Upload product image (form-data)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "image", "type": "file", "src": "" }
          ]
        },
        "url": { "raw": "http://localhost:4000/uploads/product/{{productId}}", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["uploads","product","{{productId}}"] }
      }
    }
  ]
}
