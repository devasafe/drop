# 🔧 CONFIGURAÇÃO DO AMBIENTE
# Copie este arquivo para .env e configure os valores

# ==============================================
# 📌 AMBIENTE
# ==============================================
NODE_ENV=development
PORT=4000

# ==============================================
# 🗄️ BANCO DE DADOS
# ==============================================
MONGO_URI=mongodb://localhost:27017/drop

# ==============================================
# 🔐 SEGURANÇA & TOKENS
# ==============================================
# Gere uma chave secreta segura: `openssl rand -base64 32`
JWT_SECRET=sua_chave_secreta_super_segura_aqui_com_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# ==============================================
# 🌐 CORS (Origins permitidas, separadas por vírgula)
# ==============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080

# ==============================================
# 📝 LOGGING
# ==============================================
LOG_LEVEL=debug

# ==============================================
# 🔄 FEATURES
# ==============================================
ENABLE_SOCKET_IO=true
DELIVERY_TIMEOUT_MINUTES=30

# ==============================================
# ⏱️ RATE LIMITING
# ==============================================
# Quantas tentativas de login antes de bloquear
AUTH_LIMITER_MAX=5
# Em quanto tempo (milissegundos) - Default: 15 min (900000ms)
AUTH_LIMITER_WINDOW_MS=900000

# ==============================================
# 💾 REDIS (Opcional - para cache)
# ==============================================
# REDIS_URL=redis://localhost:6379

# ==============================================
# 📧 FRONTEND (Usado no frontend)
# ==============================================
NEXT_PUBLIC_API_URL=http://localhost:4000||https://xdxrxoxpx.onrender.com/api
NEXT_PUBLIC_GOOGLE_MAPS_KEY=aiZaSyAYZMvGhr79pkMvMCUPDDf8WUypLT8PKcM
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=aiZaSyAYZMvGhr79pkMvMCUPDDf8WUypLT8PKcM

