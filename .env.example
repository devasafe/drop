# 🔧 CONFIGURAÇÃO DO AMBIENTE
# Copie este arquivo para .env e configure os valores.
# ⚠️ NUNCA commite o .env real nem credenciais verdadeiras aqui.

# ==============================================
# 📌 AMBIENTE
# ==============================================
NODE_ENV=development
PORT=4000

# ==============================================
# 🗄️ BANCO DE DADOS
# ⚠️ Produção: use um cluster com REPLICA SET (ex.: MongoDB Atlas).
#    O código usa transações, que NÃO funcionam em Mongo standalone.
# ==============================================
MONGO_URI=mongodb://localhost:27017/drop
# MONGODB_URI também é aceito (alias)

# ==============================================
# 🔐 SEGURANÇA & TOKENS
# ⚠️ Em produção, JWT_SECRET é OBRIGATÓRIO (o app não sobe sem ele).
#    Gere uma chave forte: openssl rand -base64 32
# ==============================================
JWT_SECRET=troque_por_uma_chave_aleatoria_com_no_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# ==============================================
# 🌐 CORS (origens permitidas, separadas por vírgula)
# Produção: coloque a URL exata do frontend (ex.: https://seu-app.vercel.app)
# ==============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# Aceitar previews da Vercel (*.vercel.app)? Apenas em ambientes não-produtivos.
ALLOW_VERCEL_PREVIEWS=false

# ==============================================
# 📝 LOGGING
# ==============================================
LOG_LEVEL=debug

# ==============================================
# 🔄 FEATURES
# ==============================================
ENABLE_SOCKET_IO=true
DELIVERY_TIMEOUT_MINUTES=30

# ==============================================
# ⏱️ RATE LIMITING
# ==============================================
AUTH_LIMITER_MAX=5
AUTH_LIMITER_WINDOW_MS=900000

# ==============================================
# 💸 GATEWAY DE PAGAMENTO / PAYOUT
# ==============================================
PAYOUT_GATEWAY=manual

# ==============================================
# 🖼️ CLOUDINARY (upload de imagens) — preencha com suas credenciais
# ==============================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==============================================
# 🗺️ GOOGLE MAPS (backend — cálculo de rota)
# ⚠️ Restrinja a chave por aplicação/IP no Google Cloud Console.
# ==============================================
GOOGLE_MAPS_API_KEY=

# ==============================================
# 🪪 VERIFICAÇÃO DE CONTA (KYC) — Fase 1
# ==============================================
# Liga o "portão": cliente só compra verificado. Deixe 'false' até o frontend
# de verificação estar no ar, senão clientes ficam sem conseguir comprar.
KYC_ENFORCED=false
# Base do frontend (link de verificação de email)
FRONTEND_URL=http://localhost:3000
# WhatsApp Cloud API (OTP do telefone) — sem isto, o código é apenas logado
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE=
# Email (Resend) — sem RESEND_API_KEY, o link de verificação é apenas logado
RESEND_API_KEY=
EMAIL_FROM=DROP <onboarding@resend.dev>

# ==============================================
# 💾 REDIS (opcional — cache)
# ==============================================
# REDIS_URL=redis://localhost:6379

# ==============================================
# 🌍 FRONTEND (variáveis NEXT_PUBLIC — ficam expostas no browser!)
# Configure-as no projeto do frontend (Vercel), não aqui.
# ==============================================
# URL da API (inclua o sufixo /api)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# ⚠️ Chave do Google Maps do frontend: gere uma chave PRÓPRIA e RESTRITA por domínio
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
